# ── Server ─────────────────────────────────────────────────────────────
# Fuso ora: Europa/Roma (TZ impostato in src/server.js per push pianificate e job)
PORT=3000
# Hostname pubblico senza schema (usato per webServiceURL pass, link landing, callback wallet, ecc.)
# Esempio deploy dedicato: ads.2wallet.app
CUSTOM_DOMAIN=www.example.com
# Opzionale: URL completo con https; se usato, allinearlo a https:// + CUSTOM_DOMAIN
BASE_URL=https://www.example.com

# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ads2wallet

# ── Auth (dashboard) ───────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── Apple Wallet (PassKit) ──────────────────────────────────────────────
PASS_TYPE_IDENTIFIER=pass.com.example.app
TEAM_IDENTIFIER=YOUR_TEAM_ID
APNS_ENV=production

# Certificates: PEM files in ./certs/ OR Base64 env vars (e.g. Railway)
SIGNER_CERT_BASE64=
SIGNER_KEY_BASE64=
WWDR_CERT_BASE64=

# ── Email (Resend) ─────────────────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=
FROM_NAME=

# ── Google Wallet (Android) ─────────────────────────────────────────────
GOOGLE_WALLET_ISSUER_ID=
# Use EITHER Base64-encoded service account JSON OR raw JSON string:
GOOGLE_WALLET_SA_BASE64=
# GOOGLE_WALLET_SERVICE_ACCOUNT_JSON=

# ── Samsung Wallet (Galaxy / Partner program) ─────────────────────────────
# Portale: https://partner.walletsvc.samsung.com/ — loyalty card, Data Fetch Link.
# Naming: sono accettati anche gli alias più corti (es. SAMSUNG_PARTNER_ID = SAMSUNG_WALLET_PARTNER_ID).

# Wallet Card ID (path Get Card Data + link atw/v3/{cert}/{card}) — OBBLIGATORIO
SAMSUNG_WALLET_CARD_ID=
# Alias: SAMSUNG_CARD_ID=

# Certificate ID onboarding (4 caratteri alfanumerici, es. 32N4) — OBBLIGATORIO
SAMSUNG_WALLET_CERTIFICATE_ID=
# Alias: SAMSUNG_CERTIFICATE_ID=

# Partner ID (stesso partnerCode portale) — OBBLIGATORIO
SAMSUNG_WALLET_PARTNER_ID=
# Alias: SAMSUNG_PARTNER_ID=

# ── Update Notification (push verso Samsung) + verifica JWT inbound ─────
# Bearer fisso alternativo alla firma JWT (se Samsung te lo fornisce già mintato)
SAMSUNG_WALLET_ACCESS_TOKEN=
# Alias: SAMSUNG_ACCESS_TOKEN=

# Chiave privata PEM (RSA) per firmare JWT AUTH outbound — path assoluto o ~/...
SAMSUNG_PRIVATE_KEY=
# Alias inline: SAMSUNG_PRIVATE_KEY_PEM= oppure SAMSUNG_WALLET_PRIVATE_KEY_PEM=

# Paese/host tsapi pubblico — {cc2} minuscolo nel default (fallback se manca samsung_wallet_cc2 sul pass)
# SAMSUNG_WALLET_DEFAULT_CC2=IT
# SAMSUNG_WALLET_TSAPI_HOST_TEMPLATE=https://{cc2}-tsapi.walletsvc.samsung.com

# Certificato / PEM per verificare il JWT inbound (file scaricato o PEM inline):
SAMSUNG_SIGNED_CERT=
# Oppure PEM esplicito: SAMSUNG_WALLET_JWT_PUBLIC_KEY_PEM="-----BEGIN CERTIFICATE-----..."

# kid header JWT (default portale Samsung)
# SAMSUNG_WALLET_JWT_KID=WLT.PRIKEY

# Se il path REST Update differisce dalla doc (molto raro)
# SAMSUNG_WALLET_UPDATE_PATH_TEMPLATE=/wltex/cards/{cardId}/updates

# Sottotipo loyalty (default others)
# SAMSUNG_WALLET_LOYALTY_SUBTYPE=others
# SAMSUNG_WALLET_ADD_LINK_HOST=https://a.swallet.link

# Solo sviluppo: NON verificare JWT sulle GET/POST inbound
# SAMSUNG_WALLET_SKIP_JWT_VERIFY=1

# ── Optional ─────────────────────────────────────────────────────────────
REPLICATE_API_TOKEN=
